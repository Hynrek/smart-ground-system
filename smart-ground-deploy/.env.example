# Copy this file to .env and adjust.
# REGISTRY = where your images live. On GHCR this must match your GitHub
# account (lowercased), so for the Hynrek account it is:
REGISTRY=ghcr.io/hynrek

# Image tag to run. Use "latest" or a version/commit tag.
TAG=latest

# SubjectAltNames for the https cert the web container issues at startup.
# Add this machine's LAN IP so phones reaching https://<lan-ip> get a
# name-matching cert. Comma-separated openssl SAN syntax.
TLS_SANS=DNS:localhost,IP:127.0.0.1,IP:192.168.1.50

# SubjectAltNames for the mosquitto TLS (8883) server cert, same syntax as
# above. Add this machine's LAN IP if backend/SmartBox clients connect over
# the network rather than from localhost/other containers.
MQTT_TLS_SANS=DNS:localhost,DNS:mosquitto,IP:127.0.0.1

# Initial dynsec admin password, used only the very first time mosquitto
# starts (i.e. when the mosquitto_dynsec volume is empty/fresh) — see
# README.md "Dynsec bootstrap". CHANGE THIS before anything but a laptop.
MQTT_DYNSEC_ADMIN_PASSWORD=change-me-please
