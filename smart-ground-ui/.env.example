# Backend base path.
# Leave as /api for same-origin (nginx in prod, Vite proxy in dev).
# Only set an absolute URL if the backend runs on a different origin.
VITE_API_BASE_URL=/api

# node-api base path (smart-ground-node's onboarding endpoints). Relative in
# dev — Vite proxies /node-api to the Node's HTTPS port (see vite.config.js);
# nginx does the equivalent same-origin proxy in production. Only set an
# absolute URL if the Node runs on a genuinely different origin than the SPA.
VITE_NODE_API_BASE_URL=/node-api/v1
